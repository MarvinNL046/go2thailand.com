  "updated_at": "2026-03-28T08:46:52Z",
  "project": "go2thailand city support cluster upgrade tracker",
  "goal": "Upgrade all English city support clusters to source-backed, non-thin, AdSense-safe, EEAT-oriented pages.",
  "scope": [
    "/city/[slug]/food/",
    "/city/[slug]/hotels/",
    "/city/[slug]/attractions/",
    "/city/[slug]/best-time-to-visit/",
    "/city/[slug]/budget/",
    "/city/[slug]/cooking-classes/",
    "/city/[slug]/muay-thai/",
    "/city/[slug]/elephant-sanctuaries/",
    "/city/[slug]/diving-snorkeling/"
  ],
  "done_definition": [
    "each of the 9 support routes in scope renders 200, or is intentionally kept noindex with strong non-thin content",
    "rendered English HTML for each route in scope contains no stale first-person AI copy",
    "rendered English HTML for each route in scope contains no scrape-era review or rating spam",
    "rendered English HTML for each route in scope contains no affiliate-first template leakage that outweighs editorial value",
    "materially unstable claims across the support cluster are web-fact-checked",
    "visible source-backed trust signals are present on routes whose templates support them, confirmed by the workflow validation pattern",
    "internal links kept or added across the support cluster point only to strong destination pages"
  ],
  "execution": {
    "mode": "sequential",
    "source_of_truth": "cities array order",
    "start_rule": "Start with execution.next_pending and continue top-to-bottom in listed city order.",
    "selection_rule": "Work top-to-bottom in listed city order. Keep next_pending set to the first city whose status is not done.",
    "next_pending": "ayutthaya",
    "route_order_within_city": [
      "food",
      "hotels",
      "attractions",
      "best-time-to-visit",
      "budget",
      "cooking-classes",
      "muay-thai",
      "elephant-sanctuaries",
      "diving-snorkeling"
    ],
    "route_selection_rule": "Within an in-progress city, work top-to-bottom in route_order_within_city. The next route is the first route in that list whose status is not done.",
    "route_transition_rules": [
      "pending -> in_progress: set when the route becomes the active route for the city selected by execution.next_pending and editing, source gathering, or validation begins",
      "in_progress -> done: set only after that route clears route-level validation for status code or intentional noindex, leak checks, visible source-backed trust-signal checks when supported, and indexing-note requirements",
      "done -> in_progress: set if the final full-cluster validation pass fails for that route before the city is marked done"
    ]
  },
  "status_rollup": {
    "route_status_values": [
      "pending",
      "in_progress",
      "done"
    ],
    "city_status_values": [
      "pending",
      "in_progress",
      "validation_pending",
      "done"
    ],
    "rules": [
      "city status pending: all 9 route statuses are pending",
      "city status in_progress: at least 1 route status is in_progress or done, and fewer than 9 route statuses are done",
      "city status validation_pending: all 9 route statuses are done, but the final full-cluster validation pass has not yet succeeded",
      "city status done: all 9 route statuses are done",
      "partial progress is allowed only as city status in_progress; a city must not be marked done while any route status is pending or in_progress",
      "all 9 route statuses may be done only provisionally while city status is validation_pending until the final full-cluster validation pass succeeds",
      "if the final full-cluster validation pass fails for any route, the failing route status returns to in_progress and the city status remains in_progress"
    ]
  },
