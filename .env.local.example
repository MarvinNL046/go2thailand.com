# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Adjust rate limiting (requests per minute)
# OPENAI_RATE_LIMIT=8

# Perplexity API Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# n8n Webhook Security
N8N_WEBHOOK_KEY=your_secure_webhook_key_here

# Development settings
NODE_ENV=development

# Anthropic Claude API (for blog content generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API (for image generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Jina AI API (for web scraping)
JINA_API_KEY=your_jina_api_key_here

# Pipeline Secret (for securing pipeline API endpoints)
PIPELINE_SECRET=your_pipeline_secret_here

# Bright Data API (fallback scraper, optional)
# BRIGHT_DATA_API_KEY=your_bright_data_api_key_here

# Resend (email / newsletter)
RESEND_API_KEY=your_resend_api_key_here
RESEND_AUDIENCE_ID=your_resend_audience_id_here

# Google Search Console API (for GSC monitoring cron)
# Create service account at https://console.cloud.google.com
# Enable Search Console API, add service account email as user in GSC
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
